# IntentRAG v2 — Environment Variables
# Copy this to .env and fill in real values

# --- Application ---
DEBUG=false

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/intentrag

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- LLM Provider (Groq — free, 14,400 requests/day) ---
# Get key from: https://console.groq.com (free, instant signup)
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# --- Cohere (optional — free tier: 1000 calls/month) ---
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# --- LangFuse (optional — free tier: 50K observations/month) ---
# Get from: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Intent Classifier ---
# Leave empty to use default: ./intent_classifier_model_roberta
INTENT_MODEL_PATH=
